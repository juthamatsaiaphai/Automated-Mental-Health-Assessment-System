    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// ==========================\n// รวมคะแนนข้อ 1–5 และ 8\n// ==========================\nlet totalScore = 0;\n\nObject.keys($json).forEach(key => {\n  if (/^(1\\.|2\\.|3\\.|4\\.|5\\.|8\\.)/.test(key)) {\n    totalScore += parseInt($json[key]) || 0;\n  }\n});\n\n\n// ==========================\n// แปลงค่า Yes/No (ข้อ 6–7)\n// ==========================\nObject.keys($json).forEach(key => {\n\n  if (/^6\\./.test(key) && $json[key] === \"ใช่\") {\n    totalScore += 2;\n  }\n\n  if (/^7\\./.test(key) && $json[key] === \"ใช่\") {\n    totalScore += 2;\n  }\n\n});\n\n\n// ==========================\n// ประเมินระดับ\n// ==========================\nlet level = \"\";\nlet levelColor = \"\";\nlet riskNote = \"\";\n\nif (totalScore >= 20) {\n  level = \"ควรได้รับการประเมินเพิ่มเติมโดยผู้เชี่ยวชาญ\";\n  levelColor = \"#D32F2F\";\n  riskNote = \"ควรได้รับการประเมินเพิ่มเติมโดยผู้เชี่ยวชาญ\";\n} \nelse if (totalScore >= 12) {\n  level = \"ควรเฝ้าระวังและดูแลตนเอง\";\n  levelColor = \"#F57C00\";\n  riskNote = \"ควรเฝ้าระวังและดูแลตนเอง\";\n} \nelse {\n  level = \"อยู่ในเกณฑ์ปกติ\";\n  levelColor = \"#2E7D32\";\n  riskNote = \"อยู่ในเกณฑ์ปกติ\";\n}\n\n\n// ==========================\n// คำแนะนำ (เพิ่มภาษาอังกฤษ)\n// ==========================\nlet advice = \"\";\nlet adviceEN = \"\";\n\nif (level === \"อยู่ในเกณฑ์ปกติ\") {\n\n  advice = \"ตอนนี้สภาพจิตใจของคุณถือว่ามีความสมดุลและแข็งแรงดีมากครับ เปรียบเหมือนต้นไม้ที่ได้รับน้ำและแสงแดดเพียงพอ สิ่งที่คุณควรทำคือรักษาความสม่ำเสมอในการดูแลตัวเอง (Self-care) ต่อไป ลองหาเวลาขอบคุณเรื่องราวดีๆ เล็กๆ น้อยๆ ในแต่ละวันเพื่อสะสมพลังบวก และเป็นกำลังใจให้คนรอบข้างในวันที่เขาเหนื่อยล้าครับ\";\n\n  adviceEN = \"Your mental health currently appears balanced and strong. Like a tree receiving sufficient sunlight and water, you are growing well. Continue maintaining consistent self-care habits. Take time to appreciate small positive moments each day and offer encouragement to those around you when they feel tired.\";\n} \nelse if (level === \"ควรเฝ้าระวังและดูแลตนเอง\") {\n\n  advice = \"ระดับนี้ใจของคุณเริ่มส่งสัญญาณเตือนว่า เริ่มเหนื่อยแล้วนะ หรือมีเรื่องให้ต้องคิดมากเกินไปหน่อย วิธีฮีลใจที่ดีที่สุดคือการอนุญาตให้ตัวเองได้ หยุดพัก จริงๆ ครับ ลองวางมือถือลดการรับรู้ข่าวสาร (Digital Detox) แล้วกลับไปทำกิจกรรมที่เคยทำให้คุณมีความสุข เช่น ฟังเพลง วาดรูป หรือกินของอร่อย หากรู้สึกอึดอัด การเขียนระบายความรู้สึกออกมาหรือหาคนที่ไว้ใจได้สักคนเพื่อพูดคุยจะช่วยลดความตึงเครียดในใจลงได้มากครับ\";\n\n  adviceEN = \"Your mind may be showing early signs of fatigue or emotional overload. The best way to heal is to allow yourself genuine rest. Try reducing digital exposure and return to activities that once brought you joy, such as listening to music, drawing, or enjoying your favorite food. Writing down your feelings or talking to someone you trust can greatly reduce emotional tension.\";\n} \nelse {\n\n  advice = \"หากคะแนนมาถึงเกณฑ์นี้ แสดงว่าพายุในใจคุณค่อนข้างหนักและอาจส่งผลกระทบต่อการใช้ชีวิตประจำวันแล้วครับ สิ่งแรกที่อยากบอกคือ คุณเก่งมากแล้วที่อดทนมาได้ถึงขนาดนี้ การขอความช่วยเหลือไม่ใช่เครื่องหมายของความอ่อนแอ แต่คือความกล้าหาญที่จะดูแลตัวเองครับ แนะนำให้หาเวลาปรึกษาผู้เชี่ยวชาญ เช่น นักจิตวิทยา หรือจิตแพทย์ เพื่อรับคำแนะนำที่ถูกต้องและตรงจุด หรือหากยังไม่สะดวก สามารถโทรสายด่วนสุขภาพจิต 1323 ได้ตลอด 24 ชั่วโมง เพื่อให้มีคนช่วยประคองใจในเบื้องต้นครับ\";\n\n  adviceEN = \"If your score falls within this range, it may indicate significant emotional distress that could be affecting your daily life. First, recognize your strength in enduring this situation. Seeking help is not a sign of weakness, but an act of courage and self-care. Consider consulting a psychologist or psychiatrist for proper guidance. If immediate support is needed, you may contact the Mental Health Hotline (1323), available 24 hours a day.\";\n}\n\n\n// ==========================\n// Certificate\n// ==========================\nconst certificateId = \"MH-\" + Date.now();\nconst issueDate = new Date().toLocaleDateString(\"th-TH\");\n\n\n// ==========================\n// ส่งออกผลลัพธ์\n// ==========================\nreturn {\n  ...$json,\n  totalScore,\n  level,\n  levelColor,\n  riskNote,\n  certificateId,\n  issueDate,\n  advice,\n  adviceEN\n};"
      },
