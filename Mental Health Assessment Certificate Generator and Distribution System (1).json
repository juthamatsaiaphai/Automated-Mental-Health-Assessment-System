      "parameters": {
        "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<style>\n@page {\n  size: A4;\n  margin: 0;\n}\n\nhtml, body {\n  margin: 0;\n  padding: 0;\n  font-family: 'TH Sarabun New', 'Kanit', 'Prompt', 'Segoe UI', Arial, sans-serif;\n  background: #ffffff;\n}\n\n/* ================= MAIN CONTAINER ================= */\n.container {\n  position: relative;\n  width: 210mm;\n  height: 297mm;\n  padding: 15mm 20mm; /* ลดขอบเพื่อเพิ่มพื้นที่ */\n  box-sizing: border-box;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n\n/* ขอบทอง */\n.container::before {\n  content: \"\";\n  position: absolute;\n  top: 10mm;\n  left: 10mm;\n  right: 10mm;\n  bottom: 10mm;\n  border: 1.5px solid #d4af37;\n  pointer-events: none;\n  z-index: 1;\n}\n\n.top-accent {\n  position: absolute;\n  top: 0;\n  left: 0;\n  right: 0;\n  height: 8px;\n  background: linear-gradient(to right, #b8860b, {{ $json.levelColor }}, #b8860b);\n  z-index: 2;\n}\n\n/* ================= HEADER ================= */\n.header {\n  text-align: center;\n  margin-top: 10mm;\n  margin-bottom: 5mm;\n  z-index: 3;\n}\n\nh1 {\n  font-size: 36px; \n  margin: 0;\n  color: #4b3621;\n  letter-spacing: 2px;\n}\n\n.subtitle {\n  font-size: 20px;\n  color: #8a6f2f;\n  margin-top: 5px;\n}\n\n/* ================= BODY ================= */\n.body-content {\n  text-align: center;\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  justify-content: flex-start; /* เปลี่ยนเป็นชิดบนเพื่อคุมระยะห่างเอง */\n  align-items: center;\n  z-index: 3;\n}\n\n.section-text {\n  font-size: 24px;\n  color: #666;\n  margin-top: 10px;\n}\n\n.name {\n  font-size: 42px;\n  font-weight: 700;\n  color: #1a1a1a;\n  border-bottom: 2px solid #e6d5a3;\n  padding: 0 30px 5px 30px;\n  margin: 10px 0;\n}\n\n.level-wrapper {\n  margin: 10px 0;\n}\n\n.level {\n  padding: 8px 30px;\n  font-size: 24px;\n  border-radius: 10px;\n  background: #fffdf7;\n  border: 1.5px solid #e6d5a3;\n  display: inline-block;\n}\n\n.level strong {\n  color: {{ $json.levelColor }};\n  font-size: 26px;\n}\n\n/* ================= ADVICE SECTION (ส่วนที่ล้นบ่อยที่สุด) ================= */\n.advice-box {\n  width: 95%; /* กว้างเกือบเต็มเพื่อลดจำนวนบรรทัด */\n  margin-top: 15px;\n  padding: 25px 30px;\n  box-sizing: border-box;\n  border-radius: 15px;\n  border: 1.5px solid {{ $json.levelColor }};\n  background-color: {{ $json.levelColor }}05;\n}\n\n.advice-title {\n  font-size: 22px;\n  font-weight: 600;\n  margin-bottom: 12px;\n  color: {{ $json.levelColor }};\n}\n\n.advice-content {\n  font-size: 21px; /* ลดขนาดลงเล็กน้อยเพื่อให้ใส่ข้อความยาวๆ ได้ */\n  line-height: 1.4;\n  color: #333;\n  text-align: center;\n}\n\n.advice-content em {\n  display: block;\n  margin-top: 12px;\n  font-size: 18px;\n  color: #666;\n  font-style: italic;\n  font-weight: normal;\n  line-height: 1.3;\n}\n\n/* ================= FOOTER ================= */\n.footer {\n  margin-top: auto; /* ดันลงล่างสุด */\n  padding-bottom: 10mm;\n  font-size: 16px;\n  color: #888;\n  display: flex;\n  justify-content: space-between;\n  width: 90%;\n  margin-left: auto;\n  margin-right: auto;\n  z-index: 3;\n}\n</style>\n</head>\n\n<body>\n<div class=\"container\">\n  <div class=\"top-accent\"></div>\n\n  <div class=\"header\">\n    <h1>Mental Health Assessment</h1>\n    <div class=\"subtitle\">Self-Love & Emotional Care</div>\n  </div>\n\n  <div class=\"body-content\">\n    <div class=\"section-text\">บันทึกสำรวจสุขภาพใจของ</div>\n    <div class=\"name\">{{ $json.FullName }}</div>\n\n    <div class=\"level-wrapper\">\n      <div class=\"level\">\n        ระดับความกังวล: <strong>{{ $json.level }}</strong>\n      </div>\n    </div>\n\n    <div class=\"advice-box\">\n      <div class=\"advice-title\">คำแนะนำเพื่อการรักและดูแลตนเอง</div>\n      <div class=\"advice-content\">\n        {{ $json.advice }}\n        <em>{{ $json.adviceEN }}</em>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"footer\">\n    <div style=\"font-weight: bold; color: #d4af37;\">OFFICIAL REPORT</div>\n    <div>Issue Date: {{ $json.issueDate }}</div>\n  </div>\n</div>\n</body>\n</html>"
      },
